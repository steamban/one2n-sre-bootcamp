{
	"info": {
		"name": "Student API",
		"description": "Postman collection for Student CRUD REST API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080"
		}
	],
	"item": [
		{
			"name": "Healthcheck",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/healthcheck",
					"host": ["{{baseUrl}}"],
					"path": ["healthcheck"]
				},
				"description": "Check if API is running"
			},
			"response": []
		},
		{
			"name": "Create Student",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"first_name\": \"John\",\n    \"last_name\": \"Doe\",\n    \"age\": 20,\n    \"gender\": \"Male\",\n    \"email\": \"john.doe@example.com\",\n    \"phone\": \"1234567890\",\n    \"class\": \"11th\",\n    \"rank\": \"A\",\n    \"address_line1\": \"123 Main Street\",\n    \"address_line2\": \"Apt 4B\",\n    \"city\": \"New York\",\n    \"state\": \"NY\",\n    \"pincode\": \"123456\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/v1/students",
					"host": ["{{baseUrl}}"],
					"path": ["api", "v1", "students"]
				},
				"description": "Create a new student"
			},
			"response": []
		},
		{
			"name": "Get All Students (Paginated)",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/v1/students?limit=10&offset=0",
					"host": ["{{baseUrl}}"],
					"path": ["api", "v1", "students"],
					"query": [
						{
							"key": "limit",
							"value": "10"
						},
						{
							"key": "offset",
							"value": "0"
						}
					]
				},
				"description": "Retrieve students with pagination. Returns data, total, limit, and offset."
			},
			"response": []
		},
		{
			"name": "Get Student by ID",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/v1/students/{{studentId}}",
					"host": ["{{baseUrl}}"],
					"path": ["api", "v1", "students", "{{studentId}}"]
				},
				"description": "Retrieve a student by ID"
			},
			"response": []
		},
		{
			"name": "Update Student (Patch)",
			"request": {
				"method": "PATCH",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"first_name\": \"Jane\",\n    \"last_name\": \"Doe\",\n    \"age\": 21\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/v1/students/{{studentId}}",
					"host": ["{{baseUrl}}"],
					"path": ["api", "v1", "students", "{{studentId}}"]
				},
				"description": "Partially update a student. Returns the updated student data."
			},
			"response": []
		},
		{
			"name": "Delete Student",
			"request": {
				"method": "DELETE",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/v1/students/{{studentId}}",
					"host": ["{{baseUrl}}"],
					"path": ["api", "v1", "students", "{{studentId}}"]
				},
				"description": "Delete a student (soft delete). Returns the deleted student data."
			},
			"response": []
		}
	]
}
